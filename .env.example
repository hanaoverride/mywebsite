# YouTube channel URL
NEXT_PUBLIC_YOUTUBE_URL=https://www.youtube.com

# EmailJS - server-side (do NOT prefix with NEXT_PUBLIC_)
EMAILJS_PRIVATE_KEY=
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_TO_EMAIL=

# EmailJS - client-side
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
EMAILJS_TO_EMAIL=your_email@gmail.com
